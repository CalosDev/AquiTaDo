{
  "name": "aquita",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "description": "AquiTa.do - Directorio inteligente de negocios locales en Republica Dominicana",
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:web": "pnpm --filter @aquita/web dev",
    "dev:api": "pnpm --filter @aquita/api dev",
    "build": "pnpm --parallel -r run build",
    "build:web": "pnpm --filter @aquita/web build",
    "build:api": "pnpm --filter @aquita/api build",
    "check:encoding": "node scripts/check-encoding.mjs",
    "lint": "pnpm --parallel -r run lint",
    "typecheck": "pnpm --parallel -r --if-present run typecheck",
    "test": "pnpm --parallel -r --if-present run test",
    "test:unit": "pnpm --parallel -r --if-present run test:unit",
    "test:integration": "node scripts/run-with-qa-stack.mjs -- pnpm test:integration:workspace",
    "test:integration:workspace": "pnpm --parallel -r --if-present run test:integration",
    "test:e2e": "node scripts/run-with-qa-stack.mjs -- pnpm exec playwright test --grep-invert \"@visual|@a11y\"",
    "test:visual": "node scripts/run-with-qa-stack.mjs -- pnpm exec playwright test --grep @visual",
    "test:visual:update": "node scripts/run-with-qa-stack.mjs -- pnpm exec playwright test --grep @visual --update-snapshots",
    "test:a11y": "node scripts/run-with-qa-stack.mjs -- pnpm exec playwright test --grep @a11y",
    "test:lighthouse": "node scripts/run-with-qa-stack.mjs -- pnpm exec lhci autorun --config=./lighthouse/lighthouserc.js",
    "test:e2e:api": "pnpm --filter @aquita/api test:e2e",
    "audit:architecture": "node scripts/audit-architecture.mjs",
    "quality:check": "pnpm check:encoding && pnpm lint && pnpm audit:architecture && pnpm test",
    "qa:smoke": "pnpm lint && pnpm typecheck && pnpm test:unit",
    "qa:pr": "pnpm qa:smoke && pnpm test:integration && pnpm test:e2e && pnpm test:a11y",
    "qa:release": "pnpm qa:pr && pnpm test:visual && pnpm test:lighthouse",
    "smoke:api": "node scripts/smoke-api.mjs",
    "smoke:full": "node scripts/smoke-full.mjs",
    "smoke:saas": "node scripts/smoke-saas.mjs",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "alerts:prod": "node scripts/observability-alerts.mjs",
    "smoke:brave:roles": "node scripts/brave-role-audit.mjs",
    "smoke:brave:roles:mobile": "node scripts/brave-role-audit-mobile.mjs",
    "perf:prod": "node scripts/perf-benchmark.mjs",
    "ops:prod": "pnpm smoke:prod && pnpm alerts:prod && pnpm perf:prod",
    "keepwarm:prod": "node scripts/keep-warm-prod.mjs",
    "db:migrate": "pnpm --filter @aquita/api prisma:migrate",
    "db:migrate:deploy": "pnpm --filter @aquita/api prisma:migrate:deploy",
    "db:status": "pnpm --filter @aquita/api prisma:migrate:status",
    "db:generate": "pnpm --filter @aquita/api prisma:generate",
    "db:backfill:organizations": "pnpm --filter @aquita/api prisma:backfill:organizations",
    "db:seed": "pnpm --filter @aquita/api prisma:seed"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-plugin-react-hooks": "7.1.0-canary-c0060cf2-20260224",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "hono": "4.12.12",
      "@hono/node-server": "1.19.13",
      "lodash": "4.18.1",
      "multer": "2.1.1",
      "fast-xml-parser": "5.5.11",
      "effect": "3.21.0",
      "defu": "6.1.7",
      "express>path-to-regexp": "0.1.13",
      "@nestjs/core>path-to-regexp": "8.4.2",
      "@nestjs/platform-express>path-to-regexp": "8.4.2"
    }
  }
}
