# Production smoke
SMOKE_PROD_API_BASE_URL=https://aquitado.onrender.com
SMOKE_PROD_WEB_BASE_URL=https://aquitado.vercel.app
SMOKE_PROD_SKIP_CHECKINS=1
# SMOKE_PROD_SKIP_WEB=1
# SMOKE_PROD_MUTATE_USER=1
# SMOKE_PROD_MUTATE_OWNER=1
# SMOKE_PROD_CHECKIN_CREATE=1
# SMOKE_PROD_OWNER_PROMOTION_CREATE=1
# SMOKE_PROD_ALERT_CLIENT_ERRORS_WARN=5
# SMOKE_PROD_ALERT_POOR_VITALS_WARN=5
# SMOKE_PROD_ALERT_FAIL_ON_WARN=1
