// ============================================================
// AquiTa.do — Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  BUSINESS_OWNER
  ADMIN
}

enum OrganizationRole {
  OWNER
  MANAGER
  STAFF
}

enum OrganizationPlan {
  FREE
  GROWTH
  SCALE
}

enum OrganizationSubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  UNPAID
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELED
  NO_SHOW
}

enum BookingSource {
  PLATFORM
  DASHBOARD
  IMPORTED
}

enum TransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELED
}

enum WebhookProvider {
  STRIPE
}

enum WebhookProcessingStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum ConversationStatus {
  OPEN
  CLOSED
  CONVERTED
}

enum MessageSenderRole {
  CUSTOMER
  BUSINESS_STAFF
  SYSTEM
}

enum BusinessTier {
  BRONZE
  SILVER
  GOLD
}

enum ReviewModerationStatus {
  APPROVED
  FLAGGED
}

enum BusinessVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum BusinessPublicStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  SUSPENDED
}

enum BusinessClaimStatus {
  UNCLAIMED
  PENDING_CLAIM
  CLAIMED
  SUSPENDED
}

enum BusinessSource {
  ADMIN
  OWNER
  IMPORT
  USER_SUGGESTION
  SYSTEM
}

enum BusinessCatalogSource {
  OWNER_CREATED
  ADMIN_CREATED
  USER_SUGGESTED
  IMPORTED
  SYSTEM_MIGRATED
}

enum BusinessLifecycleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  SOFT_DELETED
}

enum BusinessClaimRequestStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
  CANCELED
}

enum OwnershipRole {
  PRIMARY_OWNER
  MANAGER
}

enum BusinessSuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BusinessDuplicateCaseStatus {
  DISMISSED
  CONFLICT
  MERGED
}

enum BusinessClaimEvidenceType {
  BUSINESS_EMAIL
  BUSINESS_PHONE
  SOCIAL_PROFILE
  TAX_DOCUMENT
  BRAND_ASSET
  MANUAL_REVIEW
  OTHER
}

enum BusinessPriceRange {
  BUDGET
  MODERATE
  PREMIUM
  LUXURY
}

enum BusinessImageType {
  COVER
  GALLERY
  MENU
  INTERIOR
  EXTERIOR
}

enum VerificationDocumentType {
  ID_CARD
  TAX_CERTIFICATE
  BUSINESS_LICENSE
  ADDRESS_PROOF
  SELFIE
  OTHER
}

enum VerificationDocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AdCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
  REJECTED
}

enum AdBillingModel {
  CPC
}

enum AdEventType {
  IMPRESSION
  CLICK
  CONVERSION
}

enum MarketReportType {
  PROVINCE_CATEGORY_DEMAND
  TRENDING_BUSINESSES
  CONVERSION_BENCHMARK
}

enum AdWalletTopupStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
}

enum WhatsAppConversationStatus {
  OPEN
  CLOSED
  ESCALATED
}

enum WhatsAppMessageDirection {
  INBOUND
  OUTBOUND
}

enum WhatsAppMessageStatus {
  RECEIVED
  PROCESSED
  SENT
  FAILED
}

enum NotificationChannel {
  WHATSAPP
  PUSH
}

enum NotificationJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum GrowthEventType {
  SEARCH_QUERY
  SEARCH_RESULT_CLICK
  CONTACT_CLICK
  WHATSAPP_CLICK
  BOOKING_INTENT
  CLAIM_CTA_CLICK
  CLAIM_REQUEST_SUBMITTED
  USER_SUGGESTION_SUBMITTED
  SHARE_CLICK
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET_COMPLETE
  GOOGLE_AUTH_SUCCESS
  LISTING_FILTER_APPLY
  LISTING_VIEW_CHANGE
  LISTING_MAP_SELECT
  PREMODERATION_FLAGGED
  PREMODERATION_RELEASED
  PREMODERATION_CONFIRMED
  BUSINESS_ONBOARDING_STEP
  BUSINESS_ONBOARDING_COMPLETE
}

enum SalesLeadStage {
  LEAD
  QUOTED
  BOOKED
  PAID
  LOST
}

model User {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(255)
  googleSubject String? @unique @db.VarChar(191)
  password  String
  phone     String?  @db.VarChar(20)
  avatarUrl String?  @db.VarChar(500)
  role      Role     @default(USER)
  loyaltyPoints         Int       @default(0)
  checkinCount          Int       @default(0)
  checkinStreak         Int       @default(0)
  lastCheckinAt         DateTime?
  twoFactorEnabled       Boolean  @default(false)
  twoFactorSecret        String?  @db.VarChar(128)
  twoFactorPendingSecret String?  @db.VarChar(128)
  twoFactorEnabledAt     DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businesses               Business[]
  reviews                  Review[]
  organizationsOwned       Organization[]                 @relation("OrganizationOwner")
  organizationMemberships  OrganizationMember[]
  organizationInvitesSent  OrganizationInvite[]           @relation("OrganizationInvitedBy")
  auditLogs                AuditLog[]                     @relation("AuditActor")
  refreshTokens            RefreshToken[]
  passwordResetTokens      PasswordResetToken[]
  bookings                 Booking[]
  promotionsCreated        Promotion[]                    @relation("PromotionCreator")
  transactionsAsBuyer      Transaction[]                  @relation("TransactionBuyer")
  conversationsAsCustomer  Conversation[]                 @relation("ConversationCustomer")
  conversationMessagesSent ConversationMessage[]          @relation("ConversationMessageSender")
  adCampaignsCreated       AdCampaign[]                   @relation("AdCampaignCreator")
  verificationReviews      BusinessVerificationDocument[] @relation("VerificationDocumentReviewer")
  marketReportsGenerated   MarketReportSnapshot[]         @relation("MarketReportGeneratedBy")
  adWalletTopupsRequested  AdWalletTopup[]                @relation("AdWalletTopupRequester")
  whatsappClickConversions WhatsAppClickConversion[]
  whatsappConversations    WhatsAppConversation[]          @relation("WhatsAppConversationCustomer")
  growthEvents             GrowthEvent[]
  favoriteBusinesses       UserFavoriteBusiness[]
  businessLists            UserBusinessList[]
  checkIns                 CheckIn[]
  salesLeadsAsCustomer     SalesLead[]                    @relation("SalesLeadCustomer")
  salesLeadsCreated        SalesLead[]                    @relation("SalesLeadCreator")
  businessesCreated        Business[]                     @relation("BusinessCreatedBy")
  businessesUpdated        Business[]                     @relation("BusinessUpdatedBy")
  claimedBusinesses        Business[]                     @relation("BusinessClaimedBy")
  businessClaimRequests    BusinessClaimRequest[]         @relation("BusinessClaimRequester")
  businessClaimReviews     BusinessClaimRequest[]         @relation("BusinessClaimReviewer")
  businessOwnershipsGranted BusinessOwnership[]          @relation("OwnershipGrantedBy")
  businessOwnershipsRevoked BusinessOwnership[]          @relation("OwnershipRevokedBy")
  businessSuggestionsSubmitted BusinessSuggestion[]       @relation("BusinessSuggestionSubmitter")
  businessSuggestionReviews BusinessSuggestion[]          @relation("BusinessSuggestionReviewer")
  duplicateCasesResolved   BusinessDuplicateCase[]        @relation("BusinessDuplicateResolver")

  @@index([email])
  @@index([loyaltyPoints])
  @@index([twoFactorEnabled])
  @@map("users")
}

model Business {
  id                      String                     @id @default(uuid())
  name                    String                     @db.VarChar(200)
  slug                    String                     @unique @db.VarChar(250)
  description             String                     @db.Text
  phone                   String?                    @db.VarChar(20)
  whatsapp                String?                    @db.VarChar(20)
  website                 String?                    @db.VarChar(255)
  email                   String?                    @db.VarChar(160)
  instagramUrl            String?                    @db.VarChar(255)
  facebookUrl             String?                    @db.VarChar(255)
  tiktokUrl               String?                    @db.VarChar(255)
  priceRange              BusinessPriceRange?
  address                 String                     @db.VarChar(500)
  latitude                Float?
  longitude               Float?
  location                Unsupported("geometry(Point, 4326)")?
  deletedAt               DateTime?
  verified                Boolean                    @default(false)
  verifiedAt              DateTime?
  verificationStatus      BusinessVerificationStatus @default(UNVERIFIED)
  publicStatus            BusinessPublicStatus       @default(PUBLISHED)
  claimStatus             BusinessClaimStatus        @default(UNCLAIMED)
  source                  BusinessSource             @default(SYSTEM)
  catalogSource           BusinessCatalogSource      @default(OWNER_CREATED)
  lifecycleStatus         BusinessLifecycleStatus    @default(PUBLISHED)
  publishedAt             DateTime?
  firstPublishedAt        DateTime?
  claimedAt               DateTime?
  claimedByUserId         String?
  claimedByUser           User?                      @relation("BusinessClaimedBy", fields: [claimedByUserId], references: [id])
  catalogManagedByAdmin   Boolean                    @default(false)
  isClaimable             Boolean                    @default(true)
  isActive                Boolean                    @default(true)
  isPublished             Boolean                    @default(true)
  isSearchable            Boolean                    @default(true)
  isDiscoverable          Boolean                    @default(true)
  verificationSubmittedAt DateTime?
  verificationReviewedAt  DateTime?
  verificationNotes       String?                    @db.VarChar(500)
  lastReviewedAt          DateTime?
  primaryManagingOrganizationId String?
  primaryManagingOrganization   Organization?         @relation("BusinessPrimaryManagingOrganization", fields: [primaryManagingOrganizationId], references: [id])
  legacyOwnerMode        Boolean                    @default(false)
  riskScore               Int                        @default(0)
  reputationScore         Decimal                    @default(0) @db.Decimal(6, 2)
  reputationTier          BusinessTier               @default(BRONZE)
  autoResponderEnabled    Boolean                    @default(false)
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt

  ownerId        String?
  owner          User?        @relation(fields: [ownerId], references: [id])
  organizationId String?
  organization   Organization? @relation("OrganizationBusinesses", fields: [organizationId], references: [id])
  createdByUserId String?
  createdByUser   User?        @relation("BusinessCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUserId String?
  updatedByUser   User?        @relation("BusinessUpdatedBy", fields: [updatedByUserId], references: [id])
  provinceId     String
  province       Province     @relation(fields: [provinceId], references: [id])
  cityId         String?
  city           City?        @relation(fields: [cityId], references: [id])
  sectorId       String?
  sector         Sector?      @relation(fields: [sectorId], references: [id])

  categories            BusinessCategory[]
  hours                 BusinessHour[]
  images                BusinessImage[]
  reviews               Review[]
  features              BusinessFeature[]
  analytics             BusinessAnalytics[]
  promotions            Promotion[]
  bookings              Booking[]
  transactions          Transaction[]
  conversations         Conversation[]
  whatsappConversations WhatsAppConversation[]
  whatsappClickEvents   WhatsAppClickConversion[]
  verificationDocuments BusinessVerificationDocument[]
  adCampaigns           AdCampaign[]
  notificationJobs      NotificationJob[]
  growthEvents          GrowthEvent[]
  favoritedByUsers      UserFavoriteBusiness[]
  listedByUsers         UserBusinessListItem[]
  checkIns              CheckIn[]
  salesLeads            SalesLead[]
  claimRequests         BusinessClaimRequest[]
  ownerships            BusinessOwnership[]
  approvedFromSuggestions BusinessSuggestion[]            @relation("BusinessSuggestionCreatedBusiness")
  primaryDuplicateCases BusinessDuplicateCase[]          @relation("BusinessDuplicatePrimary")

  @@index([name])
  @@index([slug])
  @@index([ownerId])
  @@index([organizationId])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([organizationId, deletedAt, verified, createdAt])
  @@index([provinceId])
  @@index([latitude, longitude])
  @@index([deletedAt])
  @@index([verified])
  @@index([verified, createdAt])
  @@index([provinceId, verified, createdAt])
  @@index([cityId, sectorId])
  @@index([verificationStatus, createdAt])
  @@index([publicStatus, createdAt])
  @@index([claimStatus, createdAt])
  @@index([source, createdAt])
  @@index([catalogSource, createdAt])
  @@index([lifecycleStatus, createdAt])
  @@index([claimedByUserId])
  @@index([primaryManagingOrganizationId])
  @@index([isPublished, isSearchable, isDiscoverable, publicStatus])
  @@index([isActive, publicStatus, claimStatus])
  @@index([provinceId, reputationScore])
  @@index([reputationTier, reputationScore])
  @@index([createdAt])
  @@map("businesses")
}

model Organization {
  id                   String                         @id @default(uuid())
  name                 String                         @db.VarChar(150)
  slug                 String                         @unique @db.VarChar(180)
  ownerUserId          String
  ownerUser            User                           @relation("OrganizationOwner", fields: [ownerUserId], references: [id])
  plan                 OrganizationPlan               @default(FREE)
  subscriptionStatus   OrganizationSubscriptionStatus @default(ACTIVE)
  subscriptionRenewsAt DateTime?
  adWalletBalance      Decimal                        @default(0) @db.Decimal(12, 2)
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt

  businesses            Business[]                    @relation("OrganizationBusinesses")
  primaryManagedBusinesses Business[]                  @relation("BusinessPrimaryManagingOrganization")
  members               OrganizationMember[]
  invites               OrganizationInvite[]
  auditLogs             AuditLog[]
  subscription          Subscription?
  payments              Payment[]
  invoices              Invoice[]
  usageMetrics          UsageMetric[]
  promotions            Promotion[]
  bookings              Booking[]
  transactions          Transaction[]
  webhookEvents         WebhookEvent[]
  conversations         Conversation[]
  whatsappConversations WhatsAppConversation[]
  whatsappWebhookEvents WhatsAppWebhookEvent[]
  whatsappClickEvents   WhatsAppClickConversion[]
  notificationJobs      NotificationJob[]
  adCampaigns           AdCampaign[]
  verificationDocuments BusinessVerificationDocument[]
  adWalletTopups        AdWalletTopup[]
  growthEvents          GrowthEvent[]
  checkIns              CheckIn[]
  salesLeads            SalesLead[]
  claimRequests         BusinessClaimRequest[]
  businessOwnerships    BusinessOwnership[]

  @@index([ownerUserId])
  @@index([plan, subscriptionStatus])
  @@map("organizations")
}

model BusinessClaimRequest {
  id                      String                     @id @default(uuid())
  businessId              String
  business                Business                   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  requesterUserId         String
  requesterUser           User                       @relation("BusinessClaimRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  requesterOrganizationId String?
  requesterOrganization   Organization?              @relation(fields: [requesterOrganizationId], references: [id], onDelete: SetNull)
  status                  BusinessClaimRequestStatus @default(PENDING)
  evidenceType            BusinessClaimEvidenceType
  evidenceValue           String?                    @db.VarChar(255)
  notes                   String?                    @db.Text
  adminNotes              String?                    @db.Text
  reviewedByAdminId       String?
  reviewedByAdmin         User?                      @relation("BusinessClaimReviewer", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  reviewedAt              DateTime?
  approvedAt              DateTime?
  rejectedAt              DateTime?
  expiredAt               DateTime?
  canceledAt              DateTime?
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  ownership               BusinessOwnership?

  @@index([businessId, status, createdAt])
  @@index([requesterUserId, status, createdAt])
  @@index([requesterOrganizationId, status, createdAt])
  @@index([reviewedByAdminId, reviewedAt])
  @@index([status])
  @@index([createdAt])
  @@map("business_claim_requests")
}

model BusinessOwnership {
  id             String                @id @default(uuid())
  businessId     String
  organizationId String
  grantedByUserId String?
  claimRequestId String?               @unique
  role           OwnershipRole         @default(PRIMARY_OWNER)
  isActive       Boolean               @default(true)
  grantedAt      DateTime              @default(now())
  revokedAt      DateTime?
  revokedByUserId String?
  revokeReason   String?               @db.Text
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  business       Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  grantedByUser  User?                 @relation("OwnershipGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)
  revokedByUser  User?                 @relation("OwnershipRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)
  claimRequest   BusinessClaimRequest? @relation(fields: [claimRequestId], references: [id], onDelete: SetNull)

  @@index([businessId, isActive])
  @@index([organizationId, isActive])
  @@index([grantedAt])
  @@index([claimRequestId])
  @@map("business_ownerships")
}

model BusinessSuggestion {
  id                String                   @id @default(uuid())
  submittedByUserId String
  submittedByUser   User                     @relation("BusinessSuggestionSubmitter", fields: [submittedByUserId], references: [id], onDelete: Cascade)
  name              String                   @db.VarChar(200)
  description       String?                  @db.Text
  categoryId        String?
  category          Category?                @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  address           String?                  @db.VarChar(500)
  provinceId        String?
  province          Province?                @relation(fields: [provinceId], references: [id], onDelete: SetNull)
  cityId            String?
  city              City?                    @relation(fields: [cityId], references: [id], onDelete: SetNull)
  phone             String?                  @db.VarChar(20)
  whatsapp          String?                  @db.VarChar(20)
  website           String?                  @db.VarChar(255)
  email             String?                  @db.VarChar(160)
  notes             String?                  @db.Text
  status            BusinessSuggestionStatus @default(PENDING)
  reviewedByAdminId String?
  reviewedByAdmin   User?                    @relation("BusinessSuggestionReviewer", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  reviewedAt        DateTime?
  createdBusinessId String?
  createdBusiness   Business?                @relation("BusinessSuggestionCreatedBusiness", fields: [createdBusinessId], references: [id], onDelete: SetNull)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@index([submittedByUserId, status, createdAt])
  @@index([status, createdAt])
  @@index([reviewedByAdminId, reviewedAt])
  @@index([createdBusinessId])
  @@map("business_suggestions")
}

model BusinessDuplicateCase {
  id                String                     @id @default(uuid())
  clusterKey        String                     @unique @db.VarChar(255)
  status            BusinessDuplicateCaseStatus
  businessIds       Json
  reasons           Json?
  primaryBusinessId String?
  primaryBusiness   Business?                  @relation("BusinessDuplicatePrimary", fields: [primaryBusinessId], references: [id], onDelete: SetNull)
  resolvedByAdminId String?
  resolvedByAdmin   User?                      @relation("BusinessDuplicateResolver", fields: [resolvedByAdminId], references: [id], onDelete: SetNull)
  resolutionNotes   String?                    @db.Text
  resolutionMeta    Json?
  resolvedAt        DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([status, createdAt])
  @@index([resolvedByAdminId, resolvedAt])
  @@index([primaryBusinessId])
  @@map("business_duplicate_cases")
}

model OrganizationMember {
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           OrganizationRole @default(STAFF)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@id([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

model OrganizationInvite {
  id              String           @id @default(uuid())
  organizationId  String
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email           String           @db.VarChar(255)
  role            OrganizationRole @default(STAFF)
  tokenHash       String           @unique @db.VarChar(255)
  expiresAt       DateTime
  acceptedAt      DateTime?
  invitedByUserId String
  invitedByUser   User             @relation("OrganizationInvitedBy", fields: [invitedByUserId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([organizationId])
  @@index([email])
  @@index([expiresAt])
  @@map("organization_invites")
}

model Plan {
  id                     String           @id @default(uuid())
  code                   OrganizationPlan @unique
  name                   String           @db.VarChar(80)
  description            String?          @db.Text
  priceMonthly           Decimal          @db.Decimal(12, 2)
  currency               String           @default("DOP") @db.VarChar(3)
  transactionFeeBps      Int              @default(0)
  maxBusinesses          Int?
  maxMembers             Int?
  maxImagesPerBusiness   Int?
  maxPromotions          Int?
  analyticsRetentionDays Int?
  active                 Boolean          @default(true)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  subscriptions Subscription[]

  @@index([active, code])
  @@map("plans")
}

model Subscription {
  id                     String             @id @default(uuid())
  organizationId         String             @unique
  organization           Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  planId                 String
  plan                   Plan               @relation(fields: [planId], references: [id])
  status                 SubscriptionStatus @default(ACTIVE)
  providerCustomerId     String?            @db.VarChar(191)
  providerSubscriptionId String?            @unique @db.VarChar(191)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  canceledAt             DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  payments     Payment[]
  invoices     Invoice[]
  usageMetrics UsageMetric[]

  @@index([status, currentPeriodEnd])
  @@index([planId])
  @@map("subscriptions")
}

model Payment {
  id                      String        @id @default(uuid())
  organizationId          String
  organization            Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptionId          String?
  subscription            Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  provider                String        @default("stripe") @db.VarChar(40)
  providerPaymentIntentId String?       @unique @db.VarChar(191)
  amount                  Decimal       @db.Decimal(12, 2)
  currency                String        @default("DOP") @db.VarChar(3)
  status                  PaymentStatus @default(PENDING)
  paidAt                  DateTime?
  failureReason           String?       @db.VarChar(255)
  metadata                Json?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  transactions Transaction[]

  @@index([organizationId, createdAt])
  @@index([subscriptionId, createdAt])
  @@index([status, createdAt])
  @@map("payments")
}

model Invoice {
  id                String        @id @default(uuid())
  organizationId    String
  organization      Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptionId    String?
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  providerInvoiceId String?       @unique @db.VarChar(191)
  number            String?       @unique @db.VarChar(120)
  amountSubtotal    Decimal       @db.Decimal(12, 2)
  amountTax         Decimal       @db.Decimal(12, 2)
  amountTotal       Decimal       @db.Decimal(12, 2)
  currency          String        @default("DOP") @db.VarChar(3)
  status            InvoiceStatus @default(OPEN)
  issuedAt          DateTime      @default(now())
  dueAt             DateTime?
  paidAt            DateTime?
  pdfUrl            String?       @db.VarChar(500)
  metadata          Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  transactions Transaction[]

  @@index([organizationId, issuedAt])
  @@index([subscriptionId, issuedAt])
  @@index([status, dueAt])
  @@map("invoices")
}

model UsageMetric {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  metricKey      String        @db.VarChar(80)
  metricValue    Int
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime      @default(now())

  @@unique([organizationId, metricKey, periodStart, periodEnd])
  @@index([organizationId, metricKey, periodStart])
  @@index([subscriptionId, metricKey])
  @@map("usage_metrics")
}

model AuditLog {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actorUserId    String?
  actorUser      User?         @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  action         String        @db.VarChar(120)
  targetType     String        @db.VarChar(80)
  targetId       String?       @db.VarChar(191)
  metadata       Json?
  createdAt      DateTime      @default(now())

