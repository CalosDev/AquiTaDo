  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  source         String       @default("web") @db.VarChar(50)
  sessionId      String?      @db.VarChar(191)
  targetPhone    String?      @db.VarChar(30)
  metadata       Json?
  clickedAt      DateTime     @default(now())
  createdAt      DateTime     @default(now())

  @@index([businessId, clickedAt])
  @@index([organizationId, clickedAt])
  @@index([userId, clickedAt])
  @@map("whatsapp_click_conversions")
}

model NotificationJob {
  id             String                @id @default(uuid())
  queueJobId     String?               @unique @db.VarChar(191)
  organizationId String?
  organization   Organization?         @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  businessId     String?
  business       Business?             @relation(fields: [businessId], references: [id], onDelete: SetNull)
  channel        NotificationChannel
  topic          String                @db.VarChar(120)
  payload        Json
  status         NotificationJobStatus @default(PENDING)
  attempts       Int                   @default(0)
  availableAt    DateTime              @default(now())
  processedAt    DateTime?
  errorMessage   String?               @db.VarChar(500)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([status, availableAt])
  @@index([organizationId, topic, createdAt])
  @@index([businessId, topic, createdAt])
  @@map("notification_jobs")
}
